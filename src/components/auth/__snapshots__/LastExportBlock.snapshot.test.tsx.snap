exports[`AuditTimelineView — snapshots > empty state 1`] = `"<ul data-testid="audit-timeline" class="space-y-1 text-xs text-muted-foreground"><li data-testid="audit-timeline-empty" class="italic">No 2FA activity recorded yet.</li></ul>"`;

exports[`AuditTimelineView — snapshots > error state 1`] = `"<ul data-testid="audit-timeline" class="space-y-1 text-xs text-destructive"><li data-testid="audit-timeline-error">Couldn't load audit history: Network down</li></ul>"`;

exports[`AuditTimelineView — snapshots > loading state 1`] = `"<ul data-testid="audit-timeline" class="space-y-1 text-xs text-muted-foreground"><li data-testid="audit-timeline-loading" class="italic">Loading audit history…</li></ul>"`;

exports[`AuditTimelineView — snapshots > populated state with multiple known event types 1`] = `"<ul data-testid="audit-timeline" class="space-y-1 text-xs"><li data-testid="audit-row-1" class="flex items-baseline gap-2"><time class="tabular-nums text-muted-foreground">2024-05-14T12:00:00.000Z</time><span class="font-medium text-foreground">2FA enabled</span></li><li data-testid="audit-row-2" class="flex items-baseline gap-2"><time class="tabular-nums text-muted-foreground">2024-05-14T12:05:00.000Z</time><span class="font-medium text-foreground">QR / setup key refreshed</span><span class="text-muted-foreground truncate">— manual</span></li><li data-testid="audit-row-3" class="flex items-baseline gap-2"><time class="tabular-nums text-muted-foreground">2024-05-14T12:10:00.000Z</time><span class="font-medium text-foreground">Audit trail exported</span><span class="text-muted-foreground truncate">— ok</span></li></ul>"`;

exports[`LastExportBlock — snapshots (empty / loaded / corrupt states) > empty: returns nothing for unauthorized role even with an event 1`] = `""`;

exports[`LastExportBlock — snapshots (empty / loaded / corrupt states) > empty: returns nothing when role is allowed but event is null 1`] = `""`;

exports[`LastExportBlock — snapshots (empty / loaded / corrupt states) > error: corrupt JSON in details falls back to em-dashes without breaking layout 1`] = `"<div data-testid="last-export-block" class="rounded-md border border-primary/20 bg-primary/5 p-2 space-y-1"><div class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download text-primary"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg><span class="text-[10px] font-semibold text-foreground">Last export on record</span></div><div class="grid grid-cols-2 gap-x-3 gap-y-0.5 text-[10px] text-muted-foreground"><span>Time:</span><span data-testid="last-export-time" class="text-foreground tabular-nums"><TIME></span><span>Format:</span><span data-testid="last-export-format" class="text-foreground font-medium">—</span><span>Filename:</span><span data-testid="last-export-filename" class="text-foreground font-mono break-all">—</span><span>Filter:</span><span data-testid="last-export-filter" class="text-foreground">—</span><span>Date range:</span><span data-testid="last-export-daterange" class="text-foreground">—</span><span>Raw details:</span><span data-testid="last-export-raw" class="text-foreground">—</span></div></div>"`;

